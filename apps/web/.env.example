# ============================================================
# BarrioTech / GPS Street Sellers — Environment variables
# ============================================================
# Copy this file to .env and fill in real values. NEVER commit .env.
# ============================================================

# --- Database (PostgreSQL) -----------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gps_street_sellers
DB_USER=postgres
DB_PASSWORD=change-me-in-prod

# --- Auth / JWT ---------------------------------------------
JWT_SECRET=at-least-32-random-bytes-base64-or-hex
JWT_PREVIOUS_SECRET=                    # optional: only needed during rotation

# --- Web-push (VAPID) ---------------------------------------
# Generate with: npm run generate-vapid
NEXT_PUBLIC_VAPID_PUBLIC_KEY=           # browser-safe (public)
VAPID_PRIVATE_KEY=                      # SERVER-ONLY — never expose
VAPID_SUBJECT=mailto:admin@barriotech.com
# (Legacy alias: VAPID_EMAIL=... also accepted)

# --- Backups (off-site S3, optional) ------------------------
# When set, scripts/backup-db.sh uploads each dump after writing it locally.
# Works with any S3-compatible service (AWS S3, DO Spaces, Backblaze B2).
# BACKUP_S3_BUCKET=barriotech-backups
# BACKUP_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com   # omit for AWS
# BACKUP_S3_REGION=us-east-1                               # required for AWS
# BACKUP_S3_PATH=db-backups                                # default: db-backups

# --- App version (reported by /api/health) ------------------
APP_VERSION=0.1.0

# --- Supabase (legacy — used by some client-side code) -----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Transactional email (Brevo) ----------------------------
# API key from https://app.brevo.com/settings/keys/api
# Sender domain MUST be verified in Brevo (SPF + DKIM at the DNS registrar).
# andresmorales.com.co is verified — use any *@andresmorales.com.co as sender.
BREVO_API_KEY=xkeysib-your-api-key-here
EMAIL_FROM=notifications@andresmorales.com.co
EMAIL_FROM_NAME=BarrioTech