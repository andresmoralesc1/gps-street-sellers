# Test environment values for CI (CRIT-CI 2026-07-23).
#
# This file is intentionally checked into git so the GitHub Actions
# workflow has something to read when it does `loadEnv()`. None of the
# values here are real secrets — they're dummy placeholders that satisfy
# the existence check. Real secrets are injected via GitHub Actions
# `env:` keys (DB_HOST, DB_PASSWORD, JWT_SECRET, etc.) which win over
# this file because env-loader.js only assigns if the key isn't already
# in process.env.
#
# If you run tests locally and have `apps/web/.env`, that real file
# takes precedence over this one for any keys it defines (the same
# "env wins" logic).

# DB pool — overridden in CI by env vars.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gps_street_sellers_test

# JWT — overridden in CI by workflow env.
JWT_SECRET=ci-test-secret-not-real-do-not-use-in-production

# Auth admin email allowlist (used by some test paths).
ADMIN_EMAIL=admin@test.local

# VAPID push keys — base64url-encoded values of the correct byte length so
# web-push's validatePublicKey() doesn't spam "should be 65 bytes" errors
# during build (cosmetic, push disabled, but fills the log). 32-byte priv
# + 65-byte pub (0x04 + 64 bytes 0xAB), deterministic for CI.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BKurq6urq6urq6urq6urq6urq6urq6urq6urq6urq6urq6urq6urq6urq6urq6urq6urq6urq6urq6urq6urq6s
VAPID_PRIVATE_KEY=zc3Nzc3Nzc3Nzc3Nzc3Nzc3Nzc3Nzc3Nzc3Nzc3Nzc0

# Demo / portfolio access (referenced by kambelleh route in some test suites).
DEMO_ADMIN_EMAIL=admin@test.local
DEMO_ADMIN_PASSWORD=demo-password-not-real

# CSRF defense — tests send mutating requests without Origin header (curl-like).
# S3-SEC-4 (audit 2026-07-23): in production this is unset (strict). In
# .env.test we explicitly flip to permissive so existing tests don't need
# mock headers. The CI workflow's `CSRF_ALLOW_MISSING_ORIGIN: "1"` env
# also wins, but the file commits the intent so anyone running
# `node --test scripts/tests/...` locally gets the same behavior.
CSRF_ALLOW_MISSING_ORIGIN=1
